{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillspec.dev/schemas/skill.spec.v0.json",
  "title": "SkillSpec v0",
  "type": "object",
  "required": ["schema", "id", "title", "description"],
  "properties": {
    "schema": {
      "const": "skillspec/v0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "applies_when": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "rank": { "type": "integer" },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": true
      }
    },
    "elicitations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["question", "choices"],
        "properties": {
          "question": { "type": "string", "minLength": 1 },
          "required_when": {
            "type": "array",
            "items": { "type": "object" }
          },
          "choices": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "label"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "description": { "type": "string" },
                "sets": { "type": "object" },
                "route": { "type": "string" },
                "next": { "type": "string" },
                "safety": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "default": { "type": "string" },
          "max_choices": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": true
      }
    },
    "trace": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["event_log"]
        },
        "required": {
          "type": "boolean"
        },
        "record": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "input_received",
              "spec_loaded",
              "rule_evaluated",
              "rule_matched",
              "route_selected",
              "route_order_set",
              "forbid_added",
              "allow_added",
              "elicitation_requested",
              "after_success_scheduled",
              "outcome_recorded"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "states": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "snippets": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "input", "expect"],
        "additionalProperties": true
      }
    },
    "review_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
